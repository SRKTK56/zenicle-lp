# --- X(Twitter) API v2 投稿用（OAuth1.0a / 必須）---
# X Developer Portal でアプリを作成し、"Read and write" 権限でトークンを発行する
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# --- 状態保存（重複投稿防止 / 推奨）---
# Vercel Marketplace で Upstash Redis を追加すると自動で設定される
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Cron以外からの実行を拒否（推奨）---
# 任意のランダム文字列。Vercel Cron はこの値を Authorization: Bearer で自動付与する
CRON_SECRET=
