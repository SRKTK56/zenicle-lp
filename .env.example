# --- X(Twitter) API v2 投稿用（OAuth1.0a / 必須）---
# X Developer Portal でアプリを作成し、"Read and write" 権限でトークンを発行する
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# --- 状態保存（重複投稿防止 / 推奨）---
# Vercel Marketplace で Upstash Redis を追加すると自動で設定される
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Cron以外からの実行を拒否（推奨）---
# 任意のランダム文字列。Vercel Cron はこの値を Authorization: Bearer で自動付与する
CRON_SECRET=

# --- 実行結果の監視通知（任意）---
# Discordチャンネルの「連携サービス → ウェブフック」で作成したURL。毎回の実行結果(0件含む)が届く
DISCORD_WEBHOOK_URL=
# フォーラムchで毎日スレッドを増やさず1スレッドへ追記したい場合、そのスレッドのIDを指定（任意）
# 未指定だと日付ごとに新スレッドを作成する
DISCORD_THREAD_ID=
